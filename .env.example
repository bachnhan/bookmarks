# Supabase Configuration (Required for Frontend and Functions)
VITE_SUPABASE_URL="your-supabase-url.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Neon Database Configuration (Required for Netlify Functions)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Application URL (Used for Auth redirection and session security)
APP_URL="http://localhost:3000"

# Optional: Better Auth Secret (Generated via openssl rand -base64 32)
# BETTER_AUTH_SECRET="your-secret-here"
